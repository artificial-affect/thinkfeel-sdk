{
  "name": "@curvelabs.org/thinkfeel",
  "version": "0.1.4",
  "description": "Official SDK for Curve ThinkFeel API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "thinkfeel": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "test:api": "npm run build && node scripts/test-api.js",
    "test:personify": "npm run build && node scripts/test-personify.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "curve",
    "thinkfeel",
    "ai",
    "sdk",
    "cli"
  ],
  "author": "Curve Labs",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/artificial-affect/thinkfeel-sdk"
  }
}
